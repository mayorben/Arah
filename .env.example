# ── PostgreSQL (Supabase) ────────────────────────────────────────────
# Session pooler (port 5432) — works from Render's network.
# Replace YOUR_DB_PASSWORD with the password from Supabase → Settings → Database.
DATABASE_URL_OVERRIDE=postgresql+asyncpg://postgres.svmgymsvzvtddqnwwooy:Temitola%402009@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Local postgres fallback — only used when DATABASE_URL_OVERRIDE is blank.
# Start with: docker compose -f docker-compose.dev.yml up -d
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=arah
# POSTGRES_USER=arah
# POSTGRES_PASSWORD=changeme

# ── Redis (Upstash) ──────────────────────────────────────────────────
# Paste the Redis URL from: upstash.com → your database → Details
# Local fallback: redis://localhost:6379/0
REDIS_URL=rediss://default:[token]@[host].upstash.io:6379

# ── Supabase Storage ─────────────────────────────────────────────────
# Supabase → Project Settings → API Keys → service_role (secret)
